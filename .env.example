# Autonomous Crypto Trader — copy this file to .env and fill in your keys.

# ── AI brain (Google Gemini) — REQUIRED ─────────────────────────────────────
# Get keys at https://aistudio.google.com/app/apikey
# Provide one or more. Multiple keys are rotated round-robin to raise throughput
# across many coins/agents without hitting rate limits.
GEMINI_API_KEY=your_primary_gemini_key_here
GEMINI_API_KEY_2=your_second_gemini_key_here
# (optional) more: GEMINI_API_KEY_3=..., or a bundle: GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-2.5-flash

# ── Exchange / market data ──────────────────────────────────────────────────
# "auto" auto-fails-over across binance → kucoin → gate → okx → kraken → coinbase.
# Or pin one, e.g. EXCHANGE_ID=binance (on machines where binance.com is reachable).
EXCHANGE_ID=auto
QUOTE_ASSET=USDT

# ── Scale knobs (how big the bot is allowed to think/act) ───────────────────
NUM_AGENTS=6                 # number of independent autonomous agents
UNIVERSE_SIZE=60             # how many top coins (by 24h vol) the AI sees each cycle
DEEP_ANALYSIS_BUDGET=25      # coins to pull full indicators for each cycle
CYCLE_MINUTES=15             # minutes between decision cycles
STARTING_BALANCE=10000       # paper starting balance per agent

# ── Safety guardrails (the AI operates INSIDE these) ────────────────────────
TRADING_MODE=paper           # paper (default). live execution is NOT implemented.
MAX_OPEN_POSITIONS=50        # hard cap on simultaneous positions per agent
MAX_DAILY_DRAWDOWN_PCT=25    # halt new entries for the day if equity drops this %
MAX_ALLOC_PCT_PER_TRADE=40   # a single trade can't exceed this % of equity
KILL_SWITCH=0                # set to 1 (or create a file named STOP) to halt all entries

# ── Telegram (optional) — legacy chat assistant + notifications ─────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
NOTIFY_TELEGRAM=0

# ── OpenAI (optional) — only for Telegram voice transcription ───────────────
OPENAI_API_KEY=your_openai_api_key_here
