# Oscar — AI Crypto Trading Assistant
# Copy this file to .env and fill in your keys

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key — required (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key — optional, only needed for voice message transcription
OPENAI_API_KEY=your_openai_api_key_here

# Gemini model to use — gemini-1.5-flash is free tier, gemini-1.5-pro is more capable
GEMINI_MODEL=gemini-1.5-flash

# Telegram Chat ID — for periodic P&L notifications from the autonomous engine
# How to get it: send any message to your bot, then visit:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Look for "chat": {"id": <number>} in the response
TELEGRAM_CHAT_ID=your_chat_id_here
